<Window x:Class="VoiceDictation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voice Dictation"
        Width="300" Height="460"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Closing="Window_Closing"
        FontFamily="Segoe UI">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Status -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- API Key -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Sprache -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Modus -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Hotkey Info -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>     <!-- Transkript -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Button -->
        </Grid.RowDefinitions>

        <!-- ── Status Indicator ── -->
        <Border Grid.Row="0" Background="#313244" CornerRadius="8" Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Ellipse x:Name="StatusDot" Width="12" Height="12"
                         Fill="#F38BA8" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#F38BA8" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                    </Ellipse.Effect>
                </Ellipse>
                <TextBlock x:Name="StatusText" Text="Nicht verbunden"
                           Foreground="#CDD6F4" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── API Key ── -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="DEEPGRAM API KEY" Foreground="#585B70"
                       FontSize="10" FontWeight="SemiBold" LetterSpacing="1.5" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ApiKeyBox"
                         Background="#313244" Foreground="#CDD6F4"
                         BorderBrush="#45475A" BorderThickness="1"
                         Padding="10,8" FontFamily="Consolas" FontSize="12"
                         PasswordChar="●"/>
        </StackPanel>

        <!-- ── Sprache ── -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="SPRACHE" Foreground="#585B70"
                       FontSize="10" FontWeight="SemiBold" LetterSpacing="1.5" Margin="0,0,0,5"/>
            <ComboBox x:Name="LanguageCombo" Padding="10,7" FontSize="12">
                <ComboBoxItem Content="Deutsch (de)" Tag="de" IsSelected="True"/>
                <ComboBoxItem Content="Englisch (en)" Tag="en"/>
                <ComboBoxItem Content="Automatisch" Tag=""/>
            </ComboBox>
        </StackPanel>

        <!-- ── Modus ── -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="MODUS" Foreground="#585B70"
                       FontSize="10" FontWeight="SemiBold" LetterSpacing="1.5" Margin="0,0,0,5"/>
            <ComboBox x:Name="ModeCombo" Padding="10,7" FontSize="12"
                      SelectionChanged="ModeCombo_SelectionChanged">
                <ComboBoxItem Content="Toggle  (F9)" Tag="toggle" IsSelected="True"/>
                <ComboBoxItem Content="Push-to-Talk  (Rechte Strg)" Tag="ptt"/>
            </ComboBox>
        </StackPanel>

        <!-- ── Hotkey Info ── -->
        <Border Grid.Row="8" Background="#181825" CornerRadius="6" Padding="10,7">
            <TextBlock x:Name="HotkeyInfoText"
                       Text="F9 drücken um Aufnahme zu starten/stoppen"
                       Foreground="#89B4FA" FontSize="11" TextWrapping="Wrap"
                       TextAlignment="Center"/>
        </Border>

        <!-- ── Transkript Vorschau ── -->
        <Border Grid.Row="10" Background="#181825" CornerRadius="6">
            <ScrollViewer x:Name="TranscriptScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="10">
                <TextBlock x:Name="TranscriptText"
                           Foreground="#A6E3A1" FontSize="12"
                           TextWrapping="Wrap" LineHeight="20"
                           Text="Hier erscheint das erkannte Transkript …"/>
            </ScrollViewer>
        </Border>

        <!-- ── Connect / Disconnect Button ── -->
        <Button Grid.Row="12" x:Name="ConnectButton"
                Content="Verbinden"
                Click="ConnectButton_Click"
                Background="#89B4FA" Foreground="#1E1E2E"
                FontWeight="SemiBold" FontSize="13"
                BorderThickness="0" Padding="0,11"
                Cursor="Hand"/>
    </Grid>
</Window>
