<Window x:Class="VoiceDictation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voice Dictation"
        Width="300" Height="600"
        MinWidth="280" MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Visibility="Hidden"
        Icon="Resources/mic.ico"
        Background="#1E1E2E"
        Closing="Window_Closing"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Dark-themed ComboBox ToggleButton -->
        <ControlTemplate x:Key="DarkComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2"
                        Background="#313244" BorderBrush="#45475A" BorderThickness="1" CornerRadius="4"/>
                <Path x:Name="Arrow" Grid.Column="1"
                      Fill="#BAC2DE" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
        </ControlTemplate>

        <!-- Dark-themed ComboBox -->
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggleButton}"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,3,23,3" VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#313244" BorderBrush="#45475A"
                                            BorderThickness="1" CornerRadius="4"
                                            Margin="0,1,0,0"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark-themed ComboBoxItem -->
        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: Status -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>  <!-- Row 2: Button -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>     <!-- Row 4: Transkript -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Row 6: Provider -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Row 8: Whisper Model -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Row 10: API Key -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Row 12: Microphone -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Row 14: Keywords -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Row 16: Language -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Row 18: Modus -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Row 20: Toggle Shortcut -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Row 22: PTT Shortcut -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Row 24: Signal Tone -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Row 26: Hotkey Info -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Row 28: Autostart -->
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>  <!-- Row 30: Start minimized -->
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>  <!-- Row 32: VAD -->
        </Grid.RowDefinitions>

        <!-- Status Indicator -->
        <Border Grid.Row="0" Background="#313244" CornerRadius="8" Padding="12,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="12" Height="12"
                             Fill="#F38BA8" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#F38BA8" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="StatusText" Text="Not connected"
                               Foreground="#CDD6F4" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Border Background="#181825" CornerRadius="3" Height="4" Margin="0,8,0,0">
                    <Border x:Name="VuMeterBar" Background="#A6E3A1" CornerRadius="3" Height="4"
                            HorizontalAlignment="Left" Width="0"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Button -->
        <Button Grid.Row="2" x:Name="ConnectButton"
                Content="Connect"
                Click="ConnectButton_Click"
                Background="#89B4FA" Foreground="#1E1E2E"
                FontWeight="SemiBold" FontSize="14"
                BorderThickness="0" Padding="0,11"
                Cursor="Hand"/>

        <!-- Transkript Vorschau -->
        <Border Grid.Row="4" Background="#181825" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="10,6,6,0">
                    <TextBlock Text="TRANSCRIPT" Foreground="#BAC2DE"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Content="Log" Click="LogButton_Click"
                            HorizontalAlignment="Right"
                            Background="Transparent" Foreground="#6C7086"
                            FontSize="11" BorderThickness="0"
                            Padding="6,2" Cursor="Hand"/>
                </Grid>
                <ScrollViewer Grid.Row="1" x:Name="TranscriptScroll"
                              VerticalScrollBarVisibility="Auto"
                              Padding="10,4,10,10">
                    <StackPanel>
                        <TextBox x:Name="TranscriptText"
                                 Foreground="#A6E3A1" FontSize="13"
                                 TextWrapping="Wrap"
                                 Text="Transcript will appear here …"
                                 IsReadOnly="True" BorderThickness="0"
                                 Background="Transparent" Padding="0"
                                 IsTabStop="False"/>
                        <TextBlock x:Name="InterimText"
                                   Foreground="#6C7086" FontStyle="Italic" FontSize="13"
                                   TextWrapping="Wrap" LineHeight="20"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Provider -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="PROVIDER" Foreground="#BAC2DE"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="ProviderCombo" Padding="10,7" FontSize="13"
                      SelectionChanged="ProviderCombo_SelectionChanged">
                <ComboBoxItem Content="Deepgram (Cloud)" Tag="deepgram" IsSelected="True"/>
                <ComboBoxItem Content="Whisper (Local)" Tag="whisper"/>
            </ComboBox>
        </StackPanel>

        <!-- Whisper Modell -->
        <StackPanel Grid.Row="8" x:Name="WhisperModelPanel" Visibility="Collapsed">
            <TextBlock Text="WHISPER MODEL" Foreground="#BAC2DE"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="WhisperModelCombo" Grid.Column="0" Padding="10,7" FontSize="13"/>
                <Button x:Name="DownloadModelButton" Grid.Column="1" Content="&#xE118;"
                        Click="DownloadModelButton_Click"
                        Background="#89B4FA" Foreground="#1E1E2E"
                        FontFamily="Segoe MDL2 Assets" FontSize="14"
                        BorderThickness="0" Padding="10,7" Margin="6,0,0,0"
                        Cursor="Hand" ToolTip="Download model"/>
            </Grid>
            <ProgressBar x:Name="DownloadProgress" Height="4" Margin="0,6,0,0"
                         Visibility="Collapsed" Minimum="0" Maximum="100"
                         Background="#181825" Foreground="#A6E3A1"/>
        </StackPanel>

        <!-- API Key -->
        <StackPanel Grid.Row="10" x:Name="ApiKeyPanel">
            <TextBlock Text="DEEPGRAM API KEY" Foreground="#BAC2DE"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ApiKeyBox"
                         Background="#313244" Foreground="#CDD6F4"
                         BorderBrush="#45475A" BorderThickness="1"
                         Padding="10,8" FontFamily="Consolas" FontSize="13"
                         PasswordChar="●"
                         PasswordChanged="ApiKeyBox_PasswordChanged"/>
        </StackPanel>

        <!-- Mikrofon -->
        <StackPanel Grid.Row="12">
            <TextBlock Text="MICROPHONE" Foreground="#BAC2DE"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="MicrophoneCombo" Padding="10,7" FontSize="13"
                      SelectionChanged="MicrophoneCombo_SelectionChanged"/>
        </StackPanel>

        <!-- Keywords (Boost) -->
        <StackPanel Grid.Row="14" x:Name="KeywordsPanel">
            <TextBlock Text="KEYWORDS (Boost)" Foreground="#BAC2DE"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="KeywordsBox"
                     Background="#313244" Foreground="#CDD6F4"
                     BorderBrush="#45475A" BorderThickness="1"
                     Padding="10,8" FontFamily="Consolas" FontSize="13"
                     LostFocus="KeywordsBox_LostFocus"
                     ToolTip="Comma-separated terms for improved recognition (e.g. technical terms, names)"/>
        </StackPanel>

        <!-- Sprache -->
        <StackPanel Grid.Row="16">
            <TextBlock Text="LANGUAGE" Foreground="#BAC2DE"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="LanguageCombo" Padding="10,7" FontSize="13"
                      SelectionChanged="LanguageCombo_SelectionChanged">
                <ComboBoxItem Content="German (de)" Tag="de" IsSelected="True"/>
                <ComboBoxItem Content="English (en)" Tag="en"/>
                <ComboBoxItem Content="Automatic" Tag=""/>
            </ComboBox>
        </StackPanel>

        <!-- (Mode dropdown removed — both Toggle and PTT are always active) -->

        <!-- Toggle Shortcut -->
        <StackPanel Grid.Row="20">
            <TextBlock Text="TOGGLE SHORTCUT" Foreground="#BAC2DE"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="ToggleShortcutBox"
                     Background="#313244" Foreground="#CDD6F4"
                     BorderBrush="#45475A" BorderThickness="1"
                     Padding="10,8" FontSize="13"
                     IsReadOnly="True" Cursor="Hand"
                     Text="Ctrl+Alt+X"
                     GotFocus="ShortcutBox_GotFocus"
                     LostFocus="ShortcutBox_LostFocus"
                     PreviewKeyDown="ShortcutBox_PreviewKeyDown"/>
        </StackPanel>

        <!-- PTT Shortcut -->
        <StackPanel Grid.Row="22">
            <TextBlock Text="PTT SHORTCUT" Foreground="#BAC2DE"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="PttShortcutBox"
                     Background="#313244" Foreground="#CDD6F4"
                     BorderBrush="#45475A" BorderThickness="1"
                     Padding="10,8" FontSize="13"
                     IsReadOnly="True" Cursor="Hand"
                     Text="Win+L-Ctrl"
                     GotFocus="ShortcutBox_GotFocus"
                     LostFocus="ShortcutBox_LostFocus"
                     PreviewKeyDown="ShortcutBox_PreviewKeyDown"/>
        </StackPanel>

        <!-- Signalton -->
        <StackPanel Grid.Row="24">
            <TextBlock Text="SIGNAL TONE" Foreground="#BAC2DE"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="ToneCombo" Padding="10,7" FontSize="13"
                      SelectionChanged="ToneCombo_SelectionChanged">
                <ComboBoxItem Content="None (Off)" Tag="Kein"/>
                <ComboBoxItem Content="Gentle" Tag="Sanft" IsSelected="True"/>
                <ComboBoxItem Content="Click" Tag="Klick"/>
                <ComboBoxItem Content="Bell" Tag="Glocke"/>
                <ComboBoxItem Content="Deep" Tag="Tief"/>
                <ComboBoxItem Content="Double Pip" Tag="Doppel-Pip"/>
            </ComboBox>
        </StackPanel>


        <!-- Autostart -->
        <CheckBox Grid.Row="28" x:Name="AutostartCheck"
                  Content="  Start with Windows"
                  Foreground="#CDD6F4" FontSize="12"
                  Checked="AutostartCheck_Changed"
                  Unchecked="AutostartCheck_Changed"/>

        <!-- Start minimiert -->
        <CheckBox Grid.Row="30" x:Name="StartMinimizedCheck"
                  Content="  Start minimized"
                  Foreground="#CDD6F4" FontSize="12"
                  Margin="0,4,0,0"
                  Checked="StartMinimizedCheck_Changed"
                  Unchecked="StartMinimizedCheck_Changed"/>

        <!-- VAD Auto-Stop -->
        <CheckBox Grid.Row="32" x:Name="VadCheck"
                  Content="  Auto-stop on silence (3s)"
                  Foreground="#CDD6F4" FontSize="12"
                  Margin="0,4,0,0"
                  Checked="VadCheck_Changed"
                  Unchecked="VadCheck_Changed"/>
    </Grid>
</Window>
