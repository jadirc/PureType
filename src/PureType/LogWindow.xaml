<Window x:Class="PureType.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PureType – Log"
        Width="600" Height="400"
        MinWidth="300" MinHeight="200"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Consolas">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="Clear" Click="ClearButton_Click"
                Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                BorderThickness="0" Padding="8,4" Margin="0,0,0,8"
                HorizontalAlignment="Left" Cursor="Hand"/>

        <TextBox Grid.Row="1" x:Name="LogTextBox"
                 Background="{DynamicResource DeepBrush}" Foreground="{DynamicResource LabelBrush}"
                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                 FontSize="11" IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"/>
    </Grid>
</Window>
