<Window x:Class="PureType.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PureType"
        Width="300" Height="450"
        MinWidth="280" MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Visibility="Hidden"
        Icon="Resources/mic.ico"
        Background="{DynamicResource BackgroundBrush}"
        Closing="Window_Closing"
        FontFamily="Segoe UI">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: Status -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>  <!-- Row 2: Connect + Gear -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>  <!-- Row 4: Provider -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>  <!-- Row 6: Microphone -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>  <!-- Row 8: Input Mode -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>     <!-- Row 10: Transcript -->
            <RowDefinition Height="Auto"/>  <!-- Row 11: Stats -->
        </Grid.RowDefinitions>

        <!-- Status Indicator -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="12" Height="12"
                             Fill="{DynamicResource RedBrush}" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Ellipse.Effect>
                            <DropShadowEffect x:Name="StatusGlow" Color="#F38BA8" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="StatusText" Text="Not connected"
                               Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Border Background="{DynamicResource DeepBrush}" CornerRadius="3" Height="4" Margin="0,8,0,0">
                    <Border x:Name="VuMeterBar" Background="{DynamicResource GreenBrush}" CornerRadius="3" Height="4"
                            HorizontalAlignment="Left" Width="0"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Connect + Gear -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="ConnectButton" Content="Connect"
                    Click="ConnectButton_Click"
                    Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentForegroundBrush}"
                    FontWeight="SemiBold" FontSize="14"
                    BorderThickness="0" Padding="0,11" Cursor="Hand"/>
            <Button Grid.Column="1" x:Name="SettingsButton" Content="&#xE713;"
                    Click="SettingsButton_Click"
                    FontFamily="Segoe MDL2 Assets" FontSize="16"
                    Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                    BorderThickness="0" Padding="12,11" Margin="8,0,0,0"
                    Cursor="Hand" ToolTip="Settings"/>
        </Grid>

        <!-- Provider -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="PROVIDER" Foreground="{DynamicResource LabelBrush}"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="ProviderCombo" Padding="10,7" FontSize="13"
                      SelectionChanged="ProviderCombo_SelectionChanged">
                <ComboBoxItem Content="Deepgram (Cloud)" Tag="deepgram" IsSelected="True"/>
                <ComboBoxItem Content="Whisper (Local)" Tag="whisper"/>
            </ComboBox>
        </StackPanel>

        <!-- Microphone -->
        <StackPanel Grid.Row="6">
            <TextBlock Text="MICROPHONE" Foreground="{DynamicResource LabelBrush}"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="MicrophoneCombo" Padding="10,7" FontSize="13"
                      SelectionChanged="MicrophoneCombo_SelectionChanged"/>
        </StackPanel>

        <!-- Input Mode -->
        <StackPanel Grid.Row="8">
            <TextBlock Text="INPUT MODE" Foreground="{DynamicResource LabelBrush}"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="InputModeComboMain" Padding="10,7" FontSize="13"
                      SelectionChanged="InputModeComboMain_SelectionChanged"
                      ToolTip="Type = simulated keystrokes &#xA;Paste = clipboard + Ctrl+V &#xA;Copy = clipboard only">
                <ComboBoxItem Content="Type (simulate keystrokes)" Tag="Type" IsSelected="True"/>
                <ComboBoxItem Content="Paste (clipboard + Ctrl+V)" Tag="Paste"/>
                <ComboBoxItem Content="Copy (clipboard only)" Tag="Copy"/>
            </ComboBox>
        </StackPanel>

        <!-- Transcript -->
        <Border Grid.Row="10" Background="{DynamicResource DeepBrush}" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="10,6,6,0">
                    <TextBlock Text="TRANSCRIPT" Foreground="{DynamicResource LabelBrush}"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Export" Click="ExportButton_Click"
                                Background="Transparent" Foreground="{DynamicResource TextDimBrush}"
                                FontSize="11" BorderThickness="0"
                                Padding="6,2" Cursor="Hand"/>
                        <Button Content="History" Click="HistoryButton_Click"
                                Background="Transparent" Foreground="{DynamicResource TextDimBrush}"
                                FontSize="11" BorderThickness="0"
                                Padding="6,2" Cursor="Hand"/>
                        <Button Content="Log" Click="LogButton_Click"
                                Background="Transparent" Foreground="{DynamicResource TextDimBrush}"
                                FontSize="11" BorderThickness="0"
                                Padding="6,2" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
                <ScrollViewer Grid.Row="1" x:Name="TranscriptScroll"
                              VerticalScrollBarVisibility="Auto"
                              Padding="10,4,10,10">
                    <StackPanel>
                        <TextBox x:Name="TranscriptText"
                                 Foreground="{DynamicResource GreenBrush}" FontSize="13"
                                 TextWrapping="Wrap"
                                 Text="Transcript will appear here &#x2026;"
                                 IsReadOnly="True" BorderThickness="0"
                                 Background="Transparent" Padding="0"
                                 IsTabStop="False"/>
                        <TextBlock x:Name="InterimText"
                                   Foreground="{DynamicResource TextDimBrush}" FontStyle="Italic" FontSize="13"
                                   TextWrapping="Wrap" LineHeight="20"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Stats Summary -->
        <TextBlock Grid.Row="11" x:Name="StatsLine"
                   Text=""
                   Foreground="{DynamicResource TextDimBrush}"
                   FontSize="11" FontFamily="Segoe UI"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0"/>
    </Grid>
</Window>
