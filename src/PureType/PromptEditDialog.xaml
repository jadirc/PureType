<Window x:Class="PureType.PromptEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Prompt" Width="450" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Name -->
        <TextBlock Grid.Row="0" Text="NAME" Foreground="{DynamicResource LabelBrush}"
                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" x:Name="NameBox"
                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                 Padding="8,5" FontSize="13" Margin="0,0,0,12"/>

        <!-- Key -->
        <TextBlock Grid.Row="2" Text="TRIGGER KEY (press any key)"
                   Foreground="{DynamicResource LabelBrush}"
                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3" x:Name="KeyBox" IsReadOnly="True"
                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource AccentBrush}"
                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                 Padding="8,5" FontSize="13" FontWeight="Bold" Margin="0,0,0,4"
                 PreviewKeyDown="KeyBox_PreviewKeyDown"
                 GotFocus="KeyBox_GotFocus" LostFocus="KeyBox_LostFocus"
                 ToolTip="Click here and press any key to assign it as trigger"/>
        <TextBlock Grid.Row="3" x:Name="KeyHint"
                   Text="Click and press a key"
                   Foreground="{DynamicResource MutedTextBrush}" FontSize="10"
                   HorizontalAlignment="Right" VerticalAlignment="Center"
                   Margin="0,0,8,4" IsHitTestVisible="False"/>

        <!-- Template + Prompt -->
        <StackPanel Grid.Row="4" Margin="0,8,0,0">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="PROMPT" Foreground="{DynamicResource LabelBrush}"
                           FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" x:Name="TemplateCombo" Padding="6,4" FontSize="11"
                          HorizontalAlignment="Right" Width="180"
                          SelectionChanged="TemplateCombo_SelectionChanged">
                    <ComboBoxItem Content="(templates)" Tag="" IsSelected="True"/>
                    <ComboBoxItem Content="Correction" Tag="Clean up the following dictated text. Fix punctuation, grammar, and formatting. Keep the meaning unchanged. Reply with only the corrected text."/>
                    <ComboBoxItem Content="Summary" Tag="Summarize the following dictated text into a concise paragraph. Keep the key points. Reply with only the summary."/>
                    <ComboBoxItem Content="Translation EN&#x2192;DE" Tag="Translate the following text from English to German. Reply with only the translation."/>
                    <ComboBoxItem Content="Translation DE&#x2192;EN" Tag="Translate the following text from German to English. Reply with only the translation."/>
                    <ComboBoxItem Content="Email" Tag="Rewrite the following dictated text as a professional email. Fix grammar and formatting. Reply with only the email text."/>
                </ComboBox>
            </Grid>
            <TextBox x:Name="PromptBox"
                     Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                     Padding="8,5" FontSize="12"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Padding="16,6" Margin="0,0,8,0"
                    Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" Cursor="Hand"/>
            <Button Content="Save" Click="Save_Click" Padding="16,6"
                    Background="{DynamicResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
