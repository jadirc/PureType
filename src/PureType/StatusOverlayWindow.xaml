<Window x:Class="PureType.StatusOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        SizeToContent="WidthAndHeight"
        Background="Transparent">
    <Border Background="{DynamicResource ToastBackgroundBrush}" CornerRadius="14" Padding="12,6"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.4"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <Ellipse x:Name="StatusDot" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusText" Foreground="{DynamicResource TextDimBrush}" FontSize="12"
                       FontFamily="Segoe UI" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
