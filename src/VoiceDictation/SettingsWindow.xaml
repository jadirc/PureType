<Window x:Class="VoiceDictation.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="340" Height="520"
        MinWidth="300" MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
            <StackPanel>

                <!-- ── GENERAL ── -->
                <TextBlock Text="GENERAL" Foreground="{DynamicResource AccentBrush}"
                           FontSize="12" FontWeight="Bold" Margin="0,4,0,8"/>

                <CheckBox x:Name="AutostartCheck"
                          Content="  Start with Windows"
                          ToolTip="Automatically launch Voice Dictation when you log in to Windows."
                          Foreground="{DynamicResource TextBrush}" FontSize="12"/>

                <CheckBox x:Name="StartMinimizedCheck"
                          Content="  Start minimized"
                          ToolTip="Start the app minimized to the system tray instead of showing the main window."
                          Foreground="{DynamicResource TextBrush}" FontSize="12"
                          Margin="0,4,0,0"/>

                <!-- Theme -->
                <StackPanel Margin="0,8,0,0"
                            ToolTip="Choose a color theme. Auto follows your Windows dark/light setting and switches automatically.">
                    <TextBlock Text="THEME" Foreground="{DynamicResource LabelBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ThemeCombo" Padding="10,7" FontSize="13"
                              SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem Content="Auto (System)" Tag="Auto" IsSelected="True"/>
                        <ComboBoxItem Content="Dark" Tag="Dark"/>
                        <ComboBoxItem Content="Light" Tag="Light"/>
                    </ComboBox>
                </StackPanel>

                <!-- Text Replacements -->
                <Button Content="Text Replacements &#x2026;"
                        Click="ReplacementsButton_Click"
                        ToolTip="Define automatic text replacements that are applied to every transcription. Useful for abbreviations or frequently misrecognized words."
                        Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                        FontSize="12" BorderThickness="0"
                        Padding="0,4" Cursor="Hand"
                        HorizontalAlignment="Left"
                        Margin="0,8,0,0"/>

                <!-- Open Settings File -->
                <Button Content="Open Settings File &#x2026;"
                        Click="OpenSettingsFileButton_Click"
                        ToolTip="Open the settings JSON file in your default text editor for advanced editing."
                        Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                        FontSize="12" BorderThickness="0"
                        Padding="0,4" Cursor="Hand"
                        HorizontalAlignment="Left"
                        Margin="0,4,0,0"/>

                <!-- ── TRANSCRIPTION ── -->
                <TextBlock Text="TRANSCRIPTION" Foreground="{DynamicResource AccentBrush}"
                           FontSize="12" FontWeight="Bold" Margin="0,16,0,8"/>

                <!-- Provider -->
                <StackPanel Margin="0,0,0,12"
                            ToolTip="Select the speech recognition engine. Deepgram requires an internet connection and API key. Whisper runs locally on your machine.">
                    <TextBlock Text="PROVIDER" Foreground="{DynamicResource LabelBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ProviderCombo" Padding="10,7" FontSize="13"
                              SelectionChanged="ProviderCombo_SelectionChanged">
                        <ComboBoxItem Content="Deepgram (Cloud)" Tag="deepgram" IsSelected="True"/>
                        <ComboBoxItem Content="Whisper (Local)" Tag="whisper"/>
                    </ComboBox>
                </StackPanel>

                <!-- API Key (Deepgram only) -->
                <StackPanel x:Name="ApiKeyPanel" Margin="0,0,0,12"
                            ToolTip="Your Deepgram API key for cloud-based speech recognition. Get one at console.deepgram.com.">
                    <TextBlock Text="DEEPGRAM API KEY" Foreground="{DynamicResource LabelBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="ApiKeyBox"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                 Padding="10,8" FontFamily="Consolas" FontSize="13"
                                 PasswordChar="&#x25CF;"/>
                </StackPanel>

                <!-- Whisper Model (Whisper only) -->
                <StackPanel x:Name="WhisperModelPanel" Visibility="Collapsed" Margin="0,0,0,12"
                            ToolTip="Choose a Whisper model. Larger models are more accurate but slower. Download the model before first use.">
                    <TextBlock Text="WHISPER MODEL" Foreground="{DynamicResource LabelBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="WhisperModelCombo" Grid.Column="0" Padding="10,7" FontSize="13"/>
                        <Button x:Name="DownloadModelButton" Grid.Column="1" Content="&#xE118;"
                                Click="DownloadModelButton_Click"
                                Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentForegroundBrush}"
                                FontFamily="Segoe MDL2 Assets" FontSize="14"
                                BorderThickness="0" Padding="10,7" Margin="6,0,0,0"
                                Cursor="Hand" ToolTip="Download the selected model"/>
                    </Grid>
                    <ProgressBar x:Name="DownloadProgress" Height="4" Margin="0,6,0,0"
                                 Visibility="Collapsed" Minimum="0" Maximum="100"
                                 Background="{DynamicResource DeepBrush}" Foreground="{DynamicResource GreenBrush}"/>
                </StackPanel>

                <!-- Keywords (Deepgram only) -->
                <StackPanel x:Name="KeywordsPanel" Margin="0,0,0,12"
                            ToolTip="Comma-separated terms to boost recognition accuracy. Useful for technical terms, proper names, or domain-specific vocabulary.">
                    <TextBlock Text="KEYWORDS (Boost)" Foreground="{DynamicResource LabelBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="KeywordsBox"
                             Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                             Padding="10,8" FontFamily="Consolas" FontSize="13"/>
                </StackPanel>

                <!-- Language -->
                <StackPanel Margin="0,0,0,12"
                            ToolTip="Primary language for speech recognition. Choose Automatic to let the engine detect the language, though this may reduce accuracy.">
                    <TextBlock Text="LANGUAGE" Foreground="{DynamicResource LabelBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="LanguageCombo" Padding="10,7" FontSize="13">
                        <ComboBoxItem Content="German (de)" Tag="de" IsSelected="True"/>
                        <ComboBoxItem Content="English (en)" Tag="en"/>
                        <ComboBoxItem Content="Automatic" Tag=""/>
                    </ComboBox>
                </StackPanel>

                <!-- ── SHORTCUTS ── -->
                <TextBlock Text="SHORTCUTS" Foreground="{DynamicResource AccentBrush}"
                           FontSize="12" FontWeight="Bold" Margin="0,16,0,8"/>

                <!-- Toggle Shortcut -->
                <StackPanel Margin="0,0,0,12"
                            ToolTip="Global hotkey to start and stop recording. Click the field, then press your desired key combination.">
                    <TextBlock Text="TOGGLE SHORTCUT" Foreground="{DynamicResource LabelBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="ToggleShortcutBox"
                             Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                             Padding="10,8" FontSize="13"
                             IsReadOnly="True" Cursor="Hand"
                             Text="Ctrl+Alt+X"
                             GotFocus="ShortcutBox_GotFocus"
                             LostFocus="ShortcutBox_LostFocus"
                             PreviewKeyDown="ShortcutBox_PreviewKeyDown"/>
                </StackPanel>

                <!-- PTT Shortcut -->
                <StackPanel Margin="0,0,0,12"
                            ToolTip="Push-to-talk hotkey. Hold to record, release to stop. Works simultaneously with the toggle shortcut.">
                    <TextBlock Text="PTT SHORTCUT" Foreground="{DynamicResource LabelBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="PttShortcutBox"
                             Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                             Padding="10,8" FontSize="13"
                             IsReadOnly="True" Cursor="Hand"
                             Text="Win+L-Ctrl"
                             GotFocus="ShortcutBox_GotFocus"
                             LostFocus="ShortcutBox_LostFocus"
                             PreviewKeyDown="ShortcutBox_PreviewKeyDown"/>
                </StackPanel>

                <!-- Mute Shortcut -->
                <StackPanel Margin="0,0,0,12"
                            ToolTip="Optional hotkey to mute/unmute the microphone while connected. Press Delete or Backspace to clear. Leave empty to disable.">
                    <TextBlock Text="MUTE SHORTCUT" Foreground="{DynamicResource LabelBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="MuteShortcutBox"
                             Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                             Padding="10,8" FontSize="13"
                             IsReadOnly="True" Cursor="Hand"
                             Text=""
                             GotFocus="ShortcutBox_GotFocus"
                             LostFocus="ShortcutBox_LostFocus"
                             PreviewKeyDown="ShortcutBox_PreviewKeyDown"/>
                </StackPanel>

                <!-- ── AUDIO ── -->
                <TextBlock Text="AUDIO" Foreground="{DynamicResource AccentBrush}"
                           FontSize="12" FontWeight="Bold" Margin="0,16,0,8"/>

                <!-- Signal Tone -->
                <StackPanel Margin="0,0,0,12"
                            ToolTip="Audio feedback sound played when recording starts and stops. Choose None to disable.">
                    <TextBlock Text="SIGNAL TONE" Foreground="{DynamicResource LabelBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ToneCombo" Padding="10,7" FontSize="13">
                        <ComboBoxItem Content="None (Off)" Tag="None"/>
                        <ComboBoxItem Content="Gentle" Tag="Gentle" IsSelected="True"/>
                        <ComboBoxItem Content="Click" Tag="Click"/>
                        <ComboBoxItem Content="Bell" Tag="Bell"/>
                        <ComboBoxItem Content="Deep" Tag="Deep"/>
                        <ComboBoxItem Content="Double Pip" Tag="Double-Pip"/>
                    </ComboBox>
                </StackPanel>

                <!-- Input Delay -->
                <StackPanel Margin="0,0,0,12"
                            ToolTip="Delay in milliseconds between each simulated keystroke. Increase this if target applications drop characters. Set to 0 for instant typing.">
                    <TextBlock Text="INPUT DELAY (MS)" Foreground="{DynamicResource LabelBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="InputDelayBox"
                             Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                             Padding="10,8" FontSize="13" Text="0"
                             PreviewTextInput="InputDelayBox_PreviewTextInput"/>
                </StackPanel>

                <!-- Clipboard Mode -->
                <CheckBox x:Name="ClipboardModeCheck"
                          Content="  Clipboard mode (copy instead of type)"
                          ToolTip="Copy transcribed text to the clipboard instead of simulating keyboard input. Useful for applications that block simulated keystrokes."
                          Foreground="{DynamicResource TextBrush}" FontSize="12"
                          Margin="0,0,0,4"/>

                <!-- VAD Auto-Stop -->
                <CheckBox x:Name="VadCheck"
                          Content="  Auto-stop on silence (3s)"
                          ToolTip="Automatically stop recording after 3 seconds of silence. Useful for hands-free dictation."
                          Foreground="{DynamicResource TextBrush}" FontSize="12"
                          Margin="0,0,0,4"/>

                <!-- ── AI POST-PROCESSING ── -->
                <TextBlock Text="AI POST-PROCESSING" Foreground="{DynamicResource AccentBrush}"
                           FontSize="12" FontWeight="Bold" Margin="0,16,0,8"/>

                <CheckBox x:Name="LlmEnabledCheck"
                          Content="  AI Post-Processing"
                          ToolTip="Send transcribed text to an AI model for cleanup, translation, or formatting before typing it. Hold the AI trigger key with your shortcut to activate."
                          Foreground="{DynamicResource TextBrush}" FontSize="12"
                          Checked="LlmEnabledCheck_Changed"
                          Unchecked="LlmEnabledCheck_Changed"/>

                <StackPanel x:Name="LlmSettingsPanel" Visibility="Collapsed" Margin="0,8,0,0">
                    <StackPanel ToolTip="Hold this modifier key together with your shortcut to route the transcription through AI instead of typing it directly.">
                        <TextBlock Text="AI TRIGGER KEY" Foreground="{DynamicResource LabelBrush}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="AiTriggerKeyCombo" Padding="10,7" FontSize="13">
                            <ComboBoxItem Content="Shift" Tag="shift" IsSelected="True"/>
                            <ComboBoxItem Content="Ctrl" Tag="ctrl"/>
                            <ComboBoxItem Content="Alt" Tag="alt"/>
                            <ComboBoxItem Content="Caps Lock" Tag="caps"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="0,8,0,0"
                                ToolTip="Base URL of the OpenAI-compatible API. You can use OpenAI, Anthropic, OpenRouter, Google Gemini, or any compatible endpoint.">
                        <TextBlock Text="API ENDPOINT" Foreground="{DynamicResource LabelBrush}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="LlmBaseUrlCombo" IsEditable="True"
                                  Text="https://api.openai.com/v1"
                                  Padding="10,7" FontFamily="Consolas" FontSize="12">
                            <ComboBoxItem Content="https://api.openai.com/v1" ToolTip="OpenAI"/>
                            <ComboBoxItem Content="https://api.anthropic.com/v1" ToolTip="Anthropic Claude"/>
                            <ComboBoxItem Content="https://openrouter.ai/api/v1" ToolTip="OpenRouter"/>
                            <ComboBoxItem Content="https://generativelanguage.googleapis.com/v1beta/openai" ToolTip="Google Gemini"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="0,8,0,0"
                                ToolTip="API key for the selected AI endpoint. Required for authentication.">
                        <TextBlock Text="API KEY" Foreground="{DynamicResource LabelBrush}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="LlmApiKeyBox"
                                     Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                     Padding="10,8" FontFamily="Consolas" FontSize="13"
                                     PasswordChar="&#x25CF;"/>
                    </StackPanel>

                    <StackPanel Margin="0,8,0,0"
                                ToolTip="AI model to use for post-processing. Click the refresh button to fetch available models from the API.">
                        <TextBlock Text="MODEL" Foreground="{DynamicResource LabelBrush}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="LlmModelCombo"
                                      IsEditable="True" Text="gpt-4o-mini"
                                      Padding="10,7" FontFamily="Consolas" FontSize="13"/>
                            <Button x:Name="FetchModelsButton" Grid.Column="1" Content="&#x21BB;"
                                    Click="FetchModelsButton_Click"
                                    Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                    FontSize="16" BorderThickness="0"
                                    Padding="8,4" Margin="4,0,0,0"
                                    ToolTip="Fetch available models from the API"
                                    Cursor="Hand"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,8,0,0"
                                ToolTip="System prompt sent to the AI model. Choose a preset or write your own. The transcribed text will be appended as the user message.">
                        <TextBlock Text="SYSTEM PROMPT" Foreground="{DynamicResource LabelBrush}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <ComboBox x:Name="PromptPresetCombo" Padding="10,7" FontSize="12"
                                  SelectionChanged="PromptPresetCombo_SelectionChanged"
                                  Margin="0,0,0,5">
                            <ComboBoxItem Content="Custom" Tag="" IsSelected="True"/>
                            <ComboBoxItem Content="Correction" Tag="Clean up the following dictated text. Fix punctuation, grammar, and formatting. Keep the meaning unchanged. Reply with only the corrected text."/>
                            <ComboBoxItem Content="Summary" Tag="Summarize the following dictated text into a concise paragraph. Keep the key points. Reply with only the summary."/>
                            <ComboBoxItem Content="Translation EN&#x2192;DE" Tag="Translate the following text from English to German. Reply with only the translation."/>
                            <ComboBoxItem Content="Translation DE&#x2192;EN" Tag="Translate the following text from German to English. Reply with only the translation."/>
                            <ComboBoxItem Content="Email" Tag="Rewrite the following dictated text as a professional email. Fix grammar and formatting. Reply with only the email text."/>
                        </ComboBox>
                        <TextBox x:Name="LlmPromptBox"
                                 Text="Clean up the following dictated text. Fix punctuation, grammar, and formatting. Keep the meaning unchanged. Reply with only the corrected text."
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                 Padding="10,8" FontSize="12"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 Height="80" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancel"
                    IsCancel="True"
                    ToolTip="Discard changes and close"
                    Background="Transparent" Foreground="{DynamicResource TextBrush}"
                    FontSize="13" BorderThickness="0"
                    Padding="16,8" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="Save"
                    Click="Save_Click" IsDefault="True"
                    ToolTip="Save all settings and close"
                    Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentForegroundBrush}"
                    FontWeight="SemiBold" FontSize="13"
                    BorderThickness="0" Padding="24,8"/>
        </Grid>
    </Grid>
</Window>
