<Window x:Class="VoiceDictation.TranscriptHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transcript History"
        Width="600" Height="450"
        MinWidth="450" MinHeight="300"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- File List -->
        <Border Grid.Column="0" Background="{DynamicResource DeepBrush}" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="SESSIONS" Foreground="{DynamicResource AccentBrush}"
                           FontSize="11" FontWeight="Bold" Margin="10,8,10,6"/>
                <ListBox x:Name="FileList" Grid.Row="1"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource TextBrush}" FontSize="12"
                         SelectionChanged="FileList_SelectionChanged"
                         Padding="4,0">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </ListBox.Resources>
                </ListBox>
                <Button Grid.Row="2" Content="Open Folder"
                        Click="OpenFolderButton_Click"
                        Background="Transparent" Foreground="{DynamicResource TextDimBrush}"
                        FontSize="11" BorderThickness="0"
                        Padding="8,6" Cursor="Hand"
                        HorizontalAlignment="Left" Margin="4,0,0,4"/>
            </Grid>
        </Border>

        <!-- Content Preview -->
        <Border Grid.Column="2" Background="{DynamicResource DeepBrush}" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="PreviewHeader" Text="PREVIEW"
                           Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold"
                           Margin="10,8,10,6"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,0,10,10">
                    <TextBox x:Name="PreviewText"
                             Foreground="{DynamicResource GreenBrush}" FontSize="12"
                             TextWrapping="Wrap" IsReadOnly="True"
                             BorderThickness="0" Background="Transparent"
                             Text="Select a session to preview …"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
